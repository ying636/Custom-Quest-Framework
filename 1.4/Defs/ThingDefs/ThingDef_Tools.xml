<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <ThingDef Name = "CustomTrapBase" Abstract="True">
        <altitudeLayer>Building</altitudeLayer>
        <drawGUIOverlay>true</drawGUIOverlay>
        <useHitPoints>false</useHitPoints>
        <tickerType>Normal</tickerType>
        <passability>Standable</passability>
        <selectable>true</selectable>
        <receivesSignals>true</receivesSignals>
        <category>Attachment</category>
        <inspectorTabs>
            <li>QuestEditor_Library.ITab_CustomThing</li>
        </inspectorTabs>
        <building>
            <canPlaceOverWall>true</canPlaceOverWall>
            <deconstructible>false</deconstructible>
            <alwaysDeconstructible>false</alwaysDeconstructible>
        </building>
    </ThingDef>

    <ThingDef Name = "CustomThingBase" Abstract="True">
        <altitudeLayer>Building</altitudeLayer>
        <drawGUIOverlay>true</drawGUIOverlay>
        <useHitPoints>false</useHitPoints>
        <tickerType>Normal</tickerType>
        <passability>Standable</passability>
        <selectable>true</selectable>
        <category>Building</category>
        <receivesSignals>true</receivesSignals>
        <inspectorTabs>
            <li>QuestEditor_Library.ITab_CustomThing</li>
            <li>QuestEditor_Library.ITab_CompActionWorker</li>
            <li>QuestEditor_Library.ITab_CustomText</li>
        </inspectorTabs>
        <comps>
            <li>
                <compClass>QuestEditor_Library.CompActionWorker</compClass>
            </li>
            <li>
                <compClass>QuestEditor_Library.CompCustomText</compClass>
            </li>
        </comps>
        <building>
            <canPlaceOverWall>true</canPlaceOverWall>
            <deconstructible>false</deconstructible>
            <alwaysDeconstructible>false</alwaysDeconstructible>
        </building>
    </ThingDef>

    <ThingDef Name = "CustomToolBase" ParentName="CustomThingBase" Abstract="True">
        <graphicData>
            <graphicClass>Graphic_Single</graphicClass>
            <texPath>Spawner</texPath>
        </graphicData>
    </ThingDef>

    <ThingDef ParentName="CustomToolBase">
        <defName>QE_Spawner_Editor</defName>
        <label>Pawn spawner</label>
        <category>Attachment</category>
        <altitudeLayer>Item</altitudeLayer>
        <description>Used to generate pawns.</description>
        <thingClass>QuestEditor_Library.Spawner</thingClass>
    </ThingDef>

    <ThingDef ParentName="CustomToolBase">
        <defName>QE_LootBox</defName>
        <label>Lootbox</label>
        <description>A LootBox for testing.</description>
        <thingClass>QuestEditor_Library.LootBox</thingClass>
        <category>Building</category>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
    </ThingDef>

    <ThingDef ParentName="CustomToolBase">
        <defName>QE_InteractableThing</defName>
        <label>Interactable thing</label>
        <description>A interactable thing for testing.</description>
        <thingClass>QuestEditor_Library.InteractableThing</thingClass>
        <category>Building</category>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
    </ThingDef>

    <ThingDef ParentName="CustomToolBase">
        <defName>QE_CustomMapEntrance</defName>
        <label>Custom map entrance</label>
        <description>A entrance for testing.</description>
        <thingClass>QuestEditor_Library.CustomMapEntrance</thingClass>
        <category>Building</category>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
    </ThingDef>

    <ThingDef ParentName="CustomToolBase">
        <defName>QE_CustomMapEntrance_Chance</defName>
        <label>Custom random map entrance</label>
        <description>A entrance for testing.</description>
        <thingClass>QuestEditor_Library.CustomMapEntrance_Chance</thingClass>
        <category>Building</category>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
    </ThingDef>

    <ThingDef ParentName="CustomToolBase">
        <defName>QE_CustomMapExit</defName>
        <label>Custom map exit</label>
        <description>A exit for testing.</description>
        <thingClass>QuestEditor_Library.CustomMapExit</thingClass>
        <category>Building</category>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
    </ThingDef>

    <ThingDef ParentName="CustomTrapBase">
        <defName>QE_ZoneCore</defName>
        <label>Zone core</label>
        <description>Zone core is a tool for designing custom maps, which can be used to generate "map parts". When generating a custom map, if there is a zone core on the map, it will extract the "map parts" based on its settings for generation.</description>
        <thingClass>QuestEditor_Library.ZoneCore</thingClass>
        <category>Ethereal</category>
        <graphicData>
            <graphicClass>Graphic_Single</graphicClass>
            <texPath>ZoneCore</texPath>
        </graphicData>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
    </ThingDef>

    <ThingDef ParentName="CustomTrapBase">
        <defName>QE_CustomTrap</defName>
        <label>Custom trap</label>
        <description>A trap for testing.</description>
        <thingClass>QuestEditor_Library.CustomTrap</thingClass>
        <selectable>false</selectable>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
        <graphicData>
            <graphicClass>Graphic_Single</graphicClass>
            <texPath>Spawner</texPath>
        </graphicData>
    </ThingDef>

</Defs>  