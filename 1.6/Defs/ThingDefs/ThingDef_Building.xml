    <ThingDef ParentName="CustomToolBase">
        <defName>CQF_CryptosleepCasket</defName>
        <label>Ancient cryptosleep casket</label>
        <description>This cryptosleep casket looks like it has been here for a very long time. Who knows what it might contain?</description>
        <thingClass>QuestEditor_Library.LootBox</thingClass>
        <drawerType>MapMeshAndRealTime</drawerType>
        <graphicData>
            <texPath>Things/Building/Ship/ShipCryptosleepCasket</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1,2)</drawSize>
            <shadowData>
                <volume>(0.83, 0.3, 1.7)</volume>
            </shadowData>
        </graphicData>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>42</pathCost>
        <blockWind>true</blockWind>
        <fillPercent>0.5</fillPercent>
        <canOverlapZones>false</canOverlapZones>
        <useHitPoints>true</useHitPoints>
        <statBases>
            <MaxHitPoints>250</MaxHitPoints>
            <Flammability>1.0</Flammability>
        </statBases>
        <tickerType>Normal</tickerType>
        <size>(1,2)</size>
        <hasInteractionCell>true</hasInteractionCell>
        <interactionCellOffset>(1,0,0)</interactionCellOffset>
        <costList>
            <Steel>180</Steel>
            <Uranium>5</Uranium>
        </costList>
        <killedLeavings>
            <ChunkSlagSteel>1</ChunkSlagSteel>
            <Steel>25</Steel>
            <Uranium>3</Uranium>
        </killedLeavings>
        <building>
            <ai_chillDestination>false</ai_chillDestination>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
        <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
        <modExtensions>
            <li Class="QuestEditor_Library.ModExtension_CustomThing">
                <openedGraphicdata>
                    <texPath>Things/Building/LootBox/CryptosleepCasket/CryptosleepCasket_Opened</texPath>
                    <graphicClass>Graphic_Multi</graphicClass>
                    <drawSize>(1, 2)</drawSize>
                </openedGraphicdata>
            </li>
        </modExtensions>
    </ThingDef>

